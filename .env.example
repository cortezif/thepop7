# ---- Core ----
NODE_ENV=development
LOG_LEVEL=info

# ---- Database ----
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/thepop?schema=public
REDIS_URL=redis://localhost:6379
# Pós-venda (ADR-010): ms por "dia" de offset dos marcos D+1/D+7/D+14/D+30.
# Padrão = 1 dia real. Comprima (ex.: 1000) para testar o agendamento sem esperar dias.
# POST_SALE_DAY_MS=86400000

# ---- API ----
API_PORT=3001
API_BASE_URL=http://localhost:3001

# ---- IA ----
ANTHROPIC_API_KEY=sk-ant-xxx
CLAUDE_MODEL_AGENT=claude-sonnet-4-6
CLAUDE_MODEL_FAST=claude-haiku-4-5-20251001

# Fallbacks no cascade (opcional — agente degrada graciosamente sem essas chaves)
GROQ_API_KEY=
OLLAMA_URL=http://localhost:11434

# Voyage AI (busca semântica de produtos — adviser usa)
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-3

# ---- Meta / WhatsApp / Instagram (valores reais após aprovação Meta) ----
# Webhook (Meta painel) → {APP_PUBLIC_URL}/api/webhooks/meta, com este verify token.
META_APP_ID=
META_APP_SECRET=
META_WEBHOOK_VERIFY_TOKEN=dev-token-change-me
# WhatsApp Cloud API: sem estas duas, o connector cai pro mock (auto-detecção).
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
# Instagram (Page Access Token com instagram_manage_messages).
INSTAGRAM_ACCESS_TOKEN=

# ---- ERP / Catálogo ----
# Provedor: tray (a loja usa Tray) | bling. Default: tray.
ERP_PROVIDER=tray
# Tray Commerce (https://developer.tray.com.br)
# App OAuth: consumer_key/secret do app na Tray (necessários pro onboarding).
TRAY_CONSUMER_KEY=
TRAY_CONSUMER_SECRET=
# URL pública da app (pro callback OAuth da Tray): {APP_PUBLIC_URL}/api/auth/tray/callback
APP_PUBLIC_URL=
# Atalho de dev (token único já provisionado, sem passar pelo OAuth):
TRAY_API_URL=
TRAY_ACCESS_TOKEN=
# Bling (alternativa — https://developer.bling.com.br)
BLING_CLIENT_ID=
BLING_CLIENT_SECRET=

# ---- Logística (Melhor Envio) ----
# Sem credencial → connector cai pro mock (auto-detecção). Duas formas:
# (a) token direto do app:
MELHORENVIO_ACCESS_TOKEN=
# (b) OAuth por loja (cada loja conecta pelo botão em Configurações):
MELHORENVIO_CLIENT_ID=
MELHORENVIO_CLIENT_SECRET=

# ---- Pagamento (Mercado Pago) ----
# Sem credencial → connector cai pro mock (auto-detecção). Duas formas:
# (a) token de produção direto:
MERCADOPAGO_ACCESS_TOKEN=
# (b) OAuth por loja:
MERCADOPAGO_APP_ID=
MERCADOPAGO_APP_SECRET=

# ---- Rede de atacado B2B / MCP (ADR-024) ----
# API-key do COMPRADOR (loja/agente) que roda o servidor MCP. Emita com:
#   node --import tsx apps/mcp/src/create-buyer.ts "Nome do comprador"
# Sem key válida, o MCP roda anônimo (só leitura do catálogo).
MCP_BUYER_API_KEY=
# Comissão da plataforma por pedido B2B (fração 0..1). Default 5%.
B2B_COMMISSION_PCT=0.05
# Painel da plataforma (receita de comissoes B2B). Sem ela o painel fica off.
PLATFORM_ADMIN_KEY=

# ---- Fiscal (NFe/NFCe) ----
# Provedor: cplug (a loja usa CPlug) | plugnotas. Default: cplug.
FISCAL_PROVIDER=cplug
# CPlug / ConnectPlug (https://manual.cplug.com.br/books/api-cplug)
# Credenciais liberadas pelo time da CPlug via chamado (vinculam a loja).
CPLUG_API_URL=
CPLUG_CLIENT_ID=
CPLUG_CLIENT_SECRET=
CPLUG_STORE_USER=
CPLUG_STORE_PASSWORD=
# PlugNotas (alternativa — https://docs.plugnotas.com.br)
PLUGNOTAS_API_KEY=

# ---- Mercadológica / rede de fornecedores (ADR-029) ----
# E-mail transacional (Resend) p/ enviar pedidos de cotação. Sem isto, o envio
# usa link público + WhatsApp (não quebra). https://resend.com
RESEND_API_KEY=
EMAIL_FROM=cotacoes@suaempresa.com.br
# Domínio que recebe respostas por e-mail (plus-addressing cotacao+<token>@dominio).
# Aponte o inbound do provedor (Resend/Cloudflare/SendGrid) p/ {APP_PUBLIC_URL}/api/webhooks/email-inbound
EMAIL_INBOUND_DOMAIN=
# Segredo do cron de reenvio de cotações (worker → /cron/mercadologica-resend).
CRON_SECRET=

# ---- Segurança / LGPD (ADR-013) ----
# Chave de 32 bytes (64 chars hex) p/ criptografia de PII at-rest (phone/email/cpf).
# OBRIGATÓRIA em produção. Gere com: openssl rand -hex 32
# Em dev, se ausente, usa uma chave fixa de zeros (NÃO usar em produção).
PII_KEY=

# Auth de operador (F2): segredo do JWT (qualquer string forte) + credenciais do admin semeado.
# Em dev, JWT_SECRET tem fallback inseguro; defina em produção. Rode `node --import tsx src/seed-admin.ts` no apps/api.
JWT_SECRET=
ADMIN_EMAIL=admin@thepop7.local
ADMIN_PASSWORD=

# ---- Feature flags ----
USE_MOCK_CONNECTORS=true
