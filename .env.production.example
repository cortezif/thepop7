# ====== PRODUÇÃO — copie para .env.production e preencha ======
# NÃO comitar o .env.production (já está no .gitignore).

# Domínio do painel (com HTTPS automático). Ex.: painel.sualoja.com.br
# Pra teste sem domínio, use :80
DOMAIN=painel.sualoja.com.br

# Banco (o host "postgres" é o nome do serviço no compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=TROCAR_senha_forte_do_banco
POSTGRES_DB=thepop
DATABASE_URL=postgresql://postgres:TROCAR_senha_forte_do_banco@postgres:5432/thepop

# Segurança (gere com: openssl rand -hex 32)
PII_KEY=TROCAR_64_caracteres_hex
JWT_SECRET=TROCAR_segredo_forte

# IA
ANTHROPIC_API_KEY=sk-ant-xxx
CLAUDE_MODEL_AGENT=claude-sonnet-4-6
CLAUDE_MODEL_FAST=claude-haiku-4-5-20251001

NODE_ENV=production

# Conectores: comece com TRUE (simulado). Vire false quando as contas reais existirem.
USE_MOCK_CONNECTORS=true

# Admin inicial (usado por seed-admin)
ADMIN_EMAIL=voce@sualoja.com.br
ADMIN_PASSWORD=TROCAR_senha_do_admin

# ====== Preencher quando as contas externas forem aprovadas ======
# WhatsApp/Instagram (Meta)
# WHATSAPP_TOKEN=
# WHATSAPP_PHONE_ID=
# META_VERIFY_TOKEN=
# Bling (ERP)
# BLING_API_KEY=
# Mercado Pago
# MERCADOPAGO_ACCESS_TOKEN=
# PlugNotas (NFe)
# PLUGNOTAS_API_KEY=
