# ====== PRODUÇÃO — copie para .env.production e preencha ======
# NÃO comitar o .env.production (já está no .gitignore).

# Domínio do painel (com HTTPS automático). Ex.: painel.sualoja.com.br
# Pra teste sem domínio, use :80
DOMAIN=painel.sualoja.com.br

# Banco (o host "postgres" é o nome do serviço no compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=TROCAR_senha_forte_do_banco
POSTGRES_DB=thepop
DATABASE_URL=postgresql://postgres:TROCAR_senha_forte_do_banco@postgres:5432/thepop

# Segurança (gere com: openssl rand -hex 32)
PII_KEY=TROCAR_64_caracteres_hex
JWT_SECRET=TROCAR_segredo_forte
# Painel da plataforma (/plataforma): gestão de lojas + comissões B2B.
# Sem esta chave o painel responde 503 (o resto da app funciona normal).
PLATFORM_ADMIN_KEY=TROCAR_segredo_forte_da_plataforma

# Hardening do RLS (ADR-002): faz cada transação tenant-scoped baixar pra um
# papel Postgres SEM superuser/BYPASSRLS, então o RLS isola de fato (defesa em
# profundidade, mesmo se um filtro de tenant for esquecido no código). O papel
# `hubadvisor_app` é criado pelo rls.sql (roda no start). Vazio = desligado.
APP_DB_ROLE=hubadvisor_app

# IA — Anthropic é o principal. Os demais são FALLBACK automático (cascata):
# se a Anthropic ficar no limite/fora do ar, o sistema cai pro próximo que
# tiver chave configurada (Gemini → Groq → DeepSeek → Grok). Todos opcionais.
ANTHROPIC_API_KEY=sk-ant-xxx
CLAUDE_MODEL_AGENT=claude-sonnet-4-6
CLAUDE_MODEL_FAST=claude-haiku-4-5-20251001
# Fallbacks (opcionais — preencha os que tiver):
# GEMINI_API_KEY=        # Google AI Studio (aistudio.google.com/apikey)
# GROQ_API_KEY=          # console.groq.com/keys (free tier)
# DEEPSEEK_API_KEY=      # platform.deepseek.com
# XAI_API_KEY=           # console.x.ai  (Grok)
# Override de modelo por provedor (defaults razoáveis se omitir):
# GEMINI_MODEL=gemini-2.0-flash
# GROQ_MODEL=llama-3.3-70b-versatile
# DEEPSEEK_MODEL=deepseek-chat
# XAI_MODEL=grok-2-1212

NODE_ENV=production

# Conectores: comece com TRUE (simulado). Vire false quando as contas reais existirem.
USE_MOCK_CONNECTORS=true

# Admin inicial (usado por seed-admin)
ADMIN_EMAIL=voce@sualoja.com.br
ADMIN_PASSWORD=TROCAR_senha_do_admin

# ====== Preencher quando as contas externas forem aprovadas ======
# WhatsApp/Instagram (Meta)
# WHATSAPP_TOKEN=
# WHATSAPP_PHONE_ID=
# META_VERIFY_TOKEN=
# Bling (ERP)
# BLING_API_KEY=
# Mercado Pago
# MERCADOPAGO_ACCESS_TOKEN=
# PlugNotas (NFe)
# PLUGNOTAS_API_KEY=
