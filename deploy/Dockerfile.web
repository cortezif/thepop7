# Painel (site) — build estático com Vite, servido pelo Caddy (com HTTPS automático
# e proxy de /api → container da API).
FROM node:22-slim AS build
WORKDIR /app
COPY . .
RUN npm ci
RUN npm --workspace @hubadvisor/web run build

FROM caddy:2-alpine
COPY --from=build /app/apps/web/dist /srv
COPY deploy/Caddyfile /etc/caddy/Caddyfile
