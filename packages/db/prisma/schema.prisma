// Plataforma de Comércio Autônomo — schema multi-tenant
//
// Convenções:
// - Todas as tabelas de negócio têm `tenantId` indexado.
// - Row-Level Security é ativado por migration SQL (ver migrations/rls.sql).
// - IDs são CUIDs.
// - Timestamps em UTC. createdAt/updatedAt automáticos.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  // pgvector opcional: quando a extensão estiver disponível (Linux/Docker/cloud),
  // adicionar `vector` aqui e descomentar a coluna `embedding` em Product.
  extensions = [pgcrypto]
}

// ==========================================================
// TENANT (lojista)
// ==========================================================
model Tenant {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  status      TenantStatus @default(active)

  // Segmento da loja (ADR-029 — multi-segmento). "moda" mantém o vocabulário
  // de moda; qualquer outro valor usa enriquecimento genérico. `catalogVocab`
  // sobrescreve o vocabulário de estilos/ocasiões/tags por tenant (opcional).
  segment      String  @default("moda")
  catalogVocab Json?   // { styles?: string[], occasions?: string[] }

  // Modo fabricação (ADR-030). Ortogonal ao segmento: liga as telas de Insumos/
  // Receitas/Produção para lojas que FABRICAM o que vendem (confeitaria, marcenaria
  // sob medida, cozinha) em vez de só revender. Default false (revenda pura).
  productionEnabled Boolean @default(false)

  // Configuração do agente
  agentPersona String  @default("Maya")
  agentTone    String? // Tom de voz, brand voice — texto livre, vai pro system prompt
  policies     Json?   // FAQ, prazos, regras de troca por tenant

  // Pesos do recomendador (ADR-008)
  recoMarginWeight   Float @default(0.2)
  recoStockWeight    Float @default(0.2)
  recoProfileWeight  Float @default(0.5)

  // Kill-switch (ADR-025): quando false, a IA não responde — toda mensagem
  // que entra é parqueada pra atendimento humano (handoff). Reversível.
  aiEnabled   Boolean @default(true)

  // Auto-aprovação (ADR-025): valor máximo de pedido que a IA pode fechar
  // sozinha. Acima disso, parqueia pra confirmação humana antes de gerar PIX.
  autoApproveMaxBRL Decimal @default(1000.00) @db.Decimal(10, 2)

  // Retenção LGPD (ADR-013), diferenciada. null = desativado (nada roda sozinho).
  // Sugerido: conversas 18 meses (~540d), pedidos 5 anos (~1825d).
  retentionDays      Int?  // conversas: anonimiza conteúdo das mensagens
  orderRetentionDays Int?  // pedidos: anonimiza PII (endereço, destinatário)

  // Limites
  monthlyAIBudgetBRL Decimal @default(500.00) @db.Decimal(10, 2)

  // Cashback / fidelidade (ADR-031). Crédito acumulado por compra, com validade,
  // resgatável (abate) no próximo pedido até um teto. Default desligado.
  cashbackEnabled      Boolean @default(false)
  cashbackPct          Float   @default(10)   // % do subtotal que vira crédito
  cashbackExpiryDays   Int     @default(60)   // validade do crédito (dias)
  cashbackMaxRedeemPct Float   @default(50)   // teto: % do pedido pagável com crédito

  // Recompra automática (ADR-031): mensagem de volta p/ quem não compra há N dias.
  winbackEnabled      Boolean @default(false)
  winbackInactiveDays Int     @default(60)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users         User[]
  contacts      Contact[]
  products      Product[]
  orders        Order[]
  conversations Conversation[]
  reservations  StockReservation[]
  events        DomainEvent[]
  suppliers     Supplier[]
  purchaseRequests PurchaseRequest[]
  quotes           Quote[]
  auditLogs        AuditLog[]
  npsResponses     NpsResponse[]
  integrations     Integration[]
  productBarcodes  ProductBarcode[]
  stockMovements   StockMovement[]

  // Mercadológica / rede de fornecedores (ADR-029)
  supplierOffers   SupplierOffer[]
  priceResearches  PriceResearch[]
  priceResearchInvites PriceResearchInvite[]
  priceQuotes      PriceQuote[]
  researchAttachments ResearchAttachment[]
  adCampaigns      AdCampaign[]

  // Fabricação (ADR-030)
  rawMaterials     RawMaterial[]
  billsOfMaterials BillOfMaterials[]
  productionBatches ProductionBatch[]
  deliveryTariff   DeliveryTariff?
  cashbackEntries  CashbackEntry[]
  marketingCampaigns MarketingCampaign[]
  financialEntries FinancialEntry[]
  couriers         Courier[]
  deliveryJobs     DeliveryJob[]
  pieces           Piece[]

  @@map("tenants")
}

// Campanha de mídia paga (ADR-028 — Theo). Meta Ads (Facebook + Instagram).
model AdCampaign {
  id             String   @id @default(cuid())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name           String
  objective      String   // mensagens | trafego | vendas | reconhecimento
  platform       String   @default("meta")
  status         String   @default("rascunho") // rascunho | ativa | pausada | encerrada
  dailyBudgetBRL Decimal  @default(0) @db.Decimal(10, 2)
  audience       Json?    // { label, definition }
  creative       Json?    // { headline, primaryText, cta, imageUrl }
  externalId     String?  // id na Meta
  metrics        Json?    // { impressions, clicks, spendBRL, conversions, ctr, roas, updatedAt }
  createdBy      String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([tenantId, status])
  @@map("ad_campaigns")
}

// Razão de movimentação de estoque (ADR-009/barcode F2). Espelho/auditoria local
// do canal (a verdade do saldo é Tray/CPlug). Toda entrada/saída é um lançamento
// identificado por código de barras. `quantity` sempre positivo; o sinal vem do `type`.
enum StockMovementType {
  purchase_in  // recebimento de fornecedor
  sale_out     // venda (baixa)
  return_in    // devolução do comprador (reentra)
  adjust_in    // ajuste/balanço pra cima
  adjust_out   // perda/quebra/ajuste pra baixo
  production_in  // entrada de produto acabado vindo da produção (ADR-030)
  production_out // saída de produto acabado (consumo) — reservado p/ Fase 2
  scrap_out      // refugo/perda de produção (ADR-030)
}

model StockMovement {
  id         String  @id @default(cuid())
  tenantId   String
  tenant     Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  barcode    String
  productId  String
  variantSku String
  type       StockMovementType
  quantity   Int
  refType    String?  // "order" | "return" | "purchase_request" | "manual"
  refId      String?
  note       String?
  actor      String   @default("system") // system | operator | agent

  createdAt  DateTime @default(now())

  @@index([tenantId, barcode])
  @@index([tenantId, productId, variantSku])
  @@index([tenantId, createdAt])
  @@map("stock_movements")
}

// Código de barras por variante (ADR-004/estoque). Lookup O(1) scan→produto+variante
// e unicidade por tenant. `generated`=true → código interno (prefixo 2), gerado por
// nós; false → GTIN/EAN vindo da Tray/CPlug. Espelha o `barcode` em Product.variants.
model ProductBarcode {
  id         String  @id @default(cuid())
  tenantId   String
  tenant     Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  barcode    String
  productId  String
  variantSku String
  generated  Boolean @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([tenantId, barcode])
  @@index([tenantId, productId])
  @@map("product_barcodes")
}

// Credenciais de integração externa por tenant (ADR-004). Hoje: Tray (ERP).
// Tokens cifrados at-rest (enc:v1:) — NUNCA expor crus na API/UI/prompt.
model Integration {
  id            String   @id @default(cuid())
  tenantId      String
  provider      String   // "tray"
  status        String   @default("disconnected") // connected | disconnected | error
  apiAddress    String?  // web_api da loja (api_address devolvido pela Tray no callback)
  storeId       String?
  accessToken   String?  // cifrado
  refreshToken  String?  // cifrado
  appConfig     String?  // cifrado: JSON com credenciais de app por loja (consumer key/secret, client id/secret, tokens diretos…)
  accessExpiresAt  DateTime?
  refreshExpiresAt DateTime?
  lastError     String?
  connectedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, provider])
  @@map("integrations")
}

// NPS rastreado (ADR-017): produto e atendimento separados.
model NpsResponse {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contactId String?
  orderId   String?
  kind      String   @default("produto") // produto | atendimento
  score     Int      // 0..10
  comment   String?
  createdAt DateTime @default(now())

  @@index([tenantId, kind])
  @@index([tenantId])
  @@map("nps_responses")
}

enum TenantStatus {
  active
  suspended
  trial
}

// ==========================================================
// USER (operador humano do tenant)
// ==========================================================
model User {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  email        String
  name         String
  role         UserRole @default(operator)
  passwordHash String?  // scrypt:salt:hash (ADR-013/F2 — auth de operador)
  createdAt    DateTime @default(now())

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

enum UserRole {
  owner
  admin
  operator
}

// ==========================================================
// CONTACT (cliente final)
// ==========================================================
model Contact {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Identificadores. phone/email/cpf ficam CIFRADOS at-rest (AES-256-GCM,
  // prefixo "enc:v1:") — ADR-013. A busca/dedup usa as colunas *Hash (HMAC).
  // igHandle fica em texto puro (handle público, baixa sensibilidade).
  phone     String?  // E.164 (cifrado)
  igHandle  String?
  email     String?  // (cifrado)
  cpf       String?  // (cifrado)

  // Hashes determinísticos (HMAC-SHA256) p/ lookup exato sem decifrar.
  phoneHash String?
  emailHash String?
  cpfHash   String?

  name      String?

  // Endereço completo do cliente (cadastro CRM — ADR-039). Texto puro, mesmo
  // tratamento do endereço de entrega dos pedidos (Order.shippingAddress).
  cep         String?
  street      String?  // logradouro
  number      String?  // número
  complement  String?  // complemento
  district    String?  // bairro
  city        String?
  state       String?  // UF

  // Perfil enriquecido (ADR-007)
  height       Int?    // cm
  bust         Int?    // cm
  waist        Int?    // cm
  hips         Int?    // cm
  usualSize    String? // PP, P, M, G, GG, etc.

  // Estilo e preferências
  styles       String[] // [moderno, evangelico, festa, fitness, ...]
  occasions    String[] // [trabalho, casamento, igreja, ...]
  avoid        String[] // [decote, transparencia, ...]
  favoriteColors String[]

  // Comportamento
  avgTicket    Decimal? @db.Decimal(10, 2)
  preferredChannel String? // whatsapp | instagram
  preferredShipping String? // fast | cheap

  // Perfil/classificação (ADR-036): frequente, novo, pechincheiro, problematico,
  // atencao_humana, banido — orienta a IA (tom) e o fluxo (escalar/bloquear).
  tags         String[]

  // Privacidade
  consentLGPD  Boolean @default(false)
  optOuts      String[] // [marketing, nps, recompra]

  // Recompra automática (ADR-031): última vez que recebeu a mensagem de volta
  // (throttle anti-spam).
  lastWinbackAt DateTime?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  orders        Order[]
  conversations Conversation[]
  reservations  StockReservation[]
  cashbackEntries CashbackEntry[]

  @@index([tenantId, phoneHash])
  @@index([tenantId, emailHash])
  @@index([tenantId, cpfHash])
  @@index([tenantId, igHandle])
  @@index([tenantId])
  @@map("contacts")
}

// ==========================================================
// PRODUCT (catálogo enriquecido — ADR-006)
// ==========================================================
model Product {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  externalId   String  // SKU no ERP (Bling, Tray, etc.) ou "manual-<cuid>" se cadastrado no painel
  source       String  @default("erp") // "erp" (sincronizado do ERP/Tray) | "manual" (cadastrado no painel)
  name         String
  description  String?
  priceBRL     Decimal @db.Decimal(10, 2)
  costBRL      Decimal? @db.Decimal(10, 2)

  // Atributos enriquecidos (sugeridos por IA, revisados por lojista)
  styles       String[] // [moderno, evangelico, festa, fitness]
  occasions    String[] // [trabalho, casamento, igreja]
  neckline     String?  // alto | medio | baixo
  sheer        Boolean  @default(false)
  length       String?  // curto | medio | longo
  sleeveType   String?  // sem | curta | longa | 3-4

  // Variantes (cores, tamanhos) — JSON pra flexibilidade no MVP
  variants     Json     // [{ sku, color, size, stock, photo }]
  media        Json     // { mainPhoto, photos[], videos[] }

  // Medidas reais por tamanho (ADR-006) — { "M": { busto, cintura, quadril, comprimento } }
  measurements Json?

  // Métricas
  marginPct    Float?   // calculado
  turnoverDays Int?     // dias médios pra girar
  returnRate   Float?   // 0..1
  enrichmentStatus EnrichmentStatus @default(pending)

  // Busca semântica via pgvector (1024-dim, Voyage voyage-3 — adviser).
  // Coluna criada via migration manual quando a extensão `vector` estiver
  // habilitada (Linux/Docker/cloud). Em dev Windows nativo, busca degrada
  // pra ranking por atributos (ver apps/api/src/services/product-search.ts).
  // embedding    Unsupported("vector(1024)")?
  embeddedAt   DateTime?

  // Fabricação (ADR-030): produto feito sob encomenda (não há estoque de
  // vitrine — produz-se ao vender) vs pronta-entrega (produz pra estoque).
  // Usado como default ao registrar produção (override por lote no painel).
  madeToOrder  Boolean @default(false)

  // Prazo de encomenda em dias (ADR-030 — Fase 4): antecedência para produtos
  // sob encomenda (ex.: bolo encomendado com 2 dias). null = pronta-entrega/imediato.
  leadTimeDays Int?

  // Volume de entrega (ADR-030 — Fase 3): "tamanho" do item para decidir o modal
  // (moto vs carro). Default 1 = conta por unidade (ex.: 1 bolo = 1, limite moto 6).
  deliveryVolume Float @default(1)

  // Atacado B2B (ADR-024): lojista opta por expor o produto na rede de atacado,
  // com preço de atacado e quantidade mínima próprios.
  wholesaleEnabled  Boolean  @default(false)
  wholesalePriceBRL Decimal? @db.Decimal(10, 2)
  wholesaleMinQty   Int      @default(1)

  active       Boolean @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  reservations StockReservation[]
  orderItems   OrderItem[]

  @@unique([tenantId, externalId])
  @@index([tenantId, active])
  @@index([tenantId])
  @@map("products")
}

enum EnrichmentStatus {
  pending      // ainda não enriquecido
  ai_suggested // IA sugeriu, aguarda revisão
  approved     // lojista aprovou
}

// ==========================================================
// CONVERSATION + MESSAGE
// ==========================================================
model Conversation {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  channel   Channel
  externalConversationId String? // ID do WhatsApp/IG
  status    ConversationStatus @default(active)

  // Resumo gerado por IA pra próxima conversa começar com contexto
  summary   String?
  handoffReason String?

  // Inbox (ADR-016): organização do atendimento humano.
  tags           String[]
  assignedToId   String?
  assignedToName String?

  startedAt DateTime @default(now())
  lastMessageAt DateTime @default(now())

  // Janela de atendimento do WhatsApp (24h desde a última msg RECEBIDA do
  // cliente). Usada p/ decidir entre mensagem de sessão grátis e template pago.
  lastInboundAt     DateTime?
  waWindowExpiresAt DateTime?

  messages  Message[]
  notes     ConversationNote[]

  @@index([tenantId, status])
  @@index([tenantId, contactId])
  @@index([tenantId])
  @@map("conversations")
}

enum Channel {
  whatsapp
  instagram
  manual
}

// Nota interna do atendente (ADR-016) — nunca enviada ao cliente.
model ConversationNote {
  id             String   @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  authorId       String?
  authorName     String?
  text           String
  pinned         Boolean  @default(false) // nota fixada no topo
  createdAt      DateTime @default(now())

  @@index([conversationId, createdAt])
  @@map("conversation_notes")
}

enum ConversationStatus {
  active
  handed_off // humano assumiu
  closed
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  direction      MessageDirection
  type           MessageType @default(text)
  content        String?
  mediaUrl       String?

  // Para mensagens do agente: log da chamada à LLM
  llmModel       String?
  llmInputTokens  Int?
  llmOutputTokens Int?
  llmCachedTokens Int?
  llmCostBRL     Decimal? @db.Decimal(10, 4)
  toolCalls      Json?

  // Custo de mensageria do canal (Meta WhatsApp). waCategory ∈
  // service|utility|marketing|authentication; "service" = janela 24h = grátis.
  waCategory     String?
  waCostBRL      Decimal? @db.Decimal(10, 4)

  // Detecção de alucinação (ADR-014): flagga revisão humana.
  reviewFlagged  Boolean  @default(false)
  reviewReasons  String[]

  // Identificador da mensagem original no canal
  externalId     String?

  createdAt      DateTime @default(now())

  @@index([conversationId, createdAt])
  @@map("messages")
}

enum MessageDirection {
  in
  out
}

enum MessageType {
  text
  image
  video
  audio
  document
  system
}

// ==========================================================
// ORDER + ORDER ITEM
// ==========================================================
model Order {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  contactId String
  contact   Contact  @relation(fields: [contactId], references: [id])

  status    OrderStatus @default(created)

  // Endereço de entrega
  shippingZip       String?
  shippingAddress   Json?

  // Valores
  subtotalBRL Decimal  @db.Decimal(10, 2) @default(0)
  shippingBRL Decimal  @db.Decimal(10, 2) @default(0)
  // Cashback resgatado neste pedido (ADR-031) — abate do total.
  cashbackRedeemedBRL Decimal @db.Decimal(10, 2) @default(0)
  // Custo real do frete pago à transportadora (ADR-017). null = ainda não
  // informado → tratado como pass-through (resultado de frete 0) no financeiro.
  shippingCostBRL Decimal? @db.Decimal(10, 2)
  totalBRL    Decimal  @db.Decimal(10, 2) @default(0)

  // Pagamento
  paymentMethod  PaymentMethod?
  paymentExternalId String?       // ID no gateway
  paidAt         DateTime?

  // Logística
  carrier        String?
  trackingCode   String?
  shippedAt      DateTime?
  deliveredAt    DateTime?
  deliveredTo    String? // nome de quem recebeu

  // Fiscal
  nfeNumber      String?
  nfeXmlUrl      String?
  nfePdfUrl      String?

  // Cancelamento / devolução
  canceledAt     DateTime?
  cancelReason   String?

  externalId     String? // ID no ERP
  metadata       Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items     OrderItem[]
  returns   Return[]

  @@index([tenantId, status])
  @@index([tenantId, contactId])
  @@index([tenantId])
  @@map("orders")
}

enum OrderStatus {
  created       // criado, aguardando pagamento
  paid          // pagamento confirmado
  picking       // separação
  shipped       // postado
  in_transit
  out_for_delivery
  delivered
  finalized
  canceled
}

enum PaymentMethod {
  pix
  card
  boleto
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])

  variantSku String
  quantity   Int
  unitPriceBRL Decimal @db.Decimal(10, 2)

  @@index([orderId])
  @@map("order_items")
}

// ==========================================================
// STOCK RESERVATION (ADR-009)
// ==========================================================
model StockReservation {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  productId String
  product   Product  @relation(fields: [productId], references: [id])

  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id])

  variantSku String
  quantity   Int
  status     ReservationStatus @default(active)
  expiresAt  DateTime

  createdAt  DateTime @default(now())

  @@index([tenantId, productId, status])
  @@index([tenantId, expiresAt, status])
  @@map("stock_reservations")
}

enum ReservationStatus {
  active
  converted // virou pedido pago
  released  // expirou ou cancelada
}

// ==========================================================
// RETURN (devolução)
// ==========================================================
model Return {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id])

  status    ReturnStatus @default(requested)
  reason    String?
  reverseTrackingCode String?

  requestedAt DateTime @default(now())
  approvedAt  DateTime?
  receivedAt  DateTime?
  refundedAt  DateTime?
  refundBRL   Decimal? @db.Decimal(10, 2)

  @@index([orderId])
  @@map("returns")
}

enum ReturnStatus {
  requested
  authorized
  in_transit
  received
  analyzing
  refunded
  rejected
}

// ==========================================================
// SUPPLIER (fornecedor — para módulo de compras)
// ==========================================================
model Supplier {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name      String
  contactPhone String?
  contactEmail String?
  categories String[]

  // Cadastro (ADR-029 — mercadológica)
  document   String?  // CNPJ/CPF (opcional)
  uf         String?  // sigla do estado (PA, SP, ...)
  municipio  String?
  shareable  Boolean  @default(false) // opt-in: aparece no pool regional cross-tenant

  // Score (ADR-021)
  avgLeadTimeDays Int?
  onTimeRate      Float?
  defectRate      Float?
  relationshipScore Float @default(0.5)

  active    Boolean @default(true)
  createdAt DateTime @default(now())

  quotes      Quote[]
  offers      SupplierOffer[]
  priceQuotes PriceQuote[]

  @@index([tenantId])
  @@map("suppliers")
}

// ==========================================================
// MERCADOLÓGICA / REDE DE FORNECEDORES (ADR-029)
// Padrão portado do app C:\ple (pesquisa de preços), adaptado ao varejo privado
// (sem a camada de conformidade pública IN 65 / CEIS / SICAF).
// ==========================================================

// Tabela de preços/oferta do fornecedor — a "vitrine" que a loja consulta.
model SupplierOffer {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  item       String   // descrição do item ofertado
  sku        String?
  priceBRL   Decimal  @db.Decimal(12, 2)
  unit       String?  // un, cx, kg, ...
  validUntil DateTime?
  notes      String?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([tenantId, supplierId])
  @@index([tenantId, item])
  @@map("supplier_offers")
}

// Pesquisa de preços (campanha de cotação): item(ns) + método + prazo.
model PriceResearch {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  title        String
  items        Json     // [{ description, sku?, quantity? }]
  method       String   @default("mediana") // media | mediana | menor-preco
  deadlineDays Int      @default(5)
  status       String   @default("rascunho") // rascunho | em-coleta | encerrada
  createdBy    String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  invites      PriceResearchInvite[]
  quotes       PriceQuote[]

  @@index([tenantId, status])
  @@map("price_researches")
}

// Convite tokenizado: o pedido de cotação enviado a um fornecedor (cadastrado
// ou não). O token permite resposta pública sem conta (formulário /cotacao/<token>).
model PriceResearchInvite {
  id           String   @id @default(cuid())
  researchId   String
  research     PriceResearch @relation(fields: [researchId], references: [id], onDelete: Cascade)
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  supplierId   String?  // se for fornecedor cadastrado
  supplierName String
  email        String?
  phone        String?
  token        String   @unique
  state        String   @default("pendente") // pendente|enviado|respondido|sem-resposta|reenviado|recusado|expirado
  attempts     Int      @default(0)
  sentAt       DateTime?
  respondedAt  DateTime?

  createdAt    DateTime @default(now())

  @@index([researchId])
  @@index([token])
  @@map("price_research_invites")
}

// Cotação capturada (uma proposta de preço de um fornecedor para um item).
model PriceQuote {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  researchId   String?
  research     PriceResearch? @relation(fields: [researchId], references: [id], onDelete: SetNull)
  inviteId     String?
  supplierId   String?
  supplier     Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  supplierName String

  item         String
  unitPriceBRL Decimal  @db.Decimal(12, 2)
  quantity     Int      @default(1)
  origin       String   @default("manual") // manual|form-web|email-inbound|whatsapp-inbound|ia
  details      Json?    // { validadeAte, prazoEntregaDias, condicaoPagamento, frete, marcaModelo, observacoes }

  // Aprovação humana (cotações inbound entram pendentes)
  approvedAt   DateTime?
  approvedBy   String?
  rejectedAt   DateTime?
  rejectedBy   String?
  rejectReason String?

  createdAt    DateTime @default(now())

  @@index([tenantId, item])
  @@index([researchId])
  @@map("price_quotes")
}

// Anexo de proposta (PDF/imagem/planilha) — auditável (ADR-029). Armazenado no
// Postgres (bytea) por padrão; trocável por S3/R2 no storage-service depois.
model ResearchAttachment {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  researchId String?
  fileName   String
  mimeType   String
  sizeBytes  Int
  data       Bytes
  createdAt  DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, researchId])
  @@map("research_attachments")
}

// ==========================================================
// PURCHASE REQUEST + QUOTE (cotação — ADR-021)
// ==========================================================
model PurchaseRequest {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Itens desejados (SKU/descrição + quantidade)
  items     Json     // [{ sku?, description, quantity }]
  status    PurchaseRequestStatus @default(open)
  reason    String?  // ex: "reposição preditiva: BL-001 atingiu ponto de pedido"

  createdAt DateTime @default(now())
  closedAt  DateTime?

  quotes    Quote[]

  @@index([tenantId, status])
  @@map("purchase_requests")
}

enum PurchaseRequestStatus {
  open        // aguardando cotações
  quoted      // recebeu propostas
  ordered     // fechou com um fornecedor
  received    // mercadoria recebida e conferida
  canceled
}

model Quote {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  requestId String
  request   PurchaseRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id])

  // Extraído da resposta do fornecedor (parser IA)
  items        Json     // [{ description, unitPriceBRL, quantity }]
  totalBRL     Decimal  @db.Decimal(10, 2)
  leadTimeDays Int?
  paymentTerms String?
  rawMessage   String?  // resposta original do fornecedor (auditoria)

  // Ranking
  score        Float?
  selected     Boolean  @default(false)

  createdAt DateTime @default(now())

  @@index([tenantId, requestId])
  @@map("quotes")
}

// ==========================================================
// DOMAIN EVENT (audit trail + event bus)
// ==========================================================
model DomainEvent {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  type      String   // ex: order.paid, message.received, return.requested
  aggregateType String? // order | conversation | product
  aggregateId   String?

  payload   Json
  actor     String?  // user:xxx | agent | system | external

  createdAt DateTime @default(now())

  @@index([tenantId, type, createdAt])
  @@index([tenantId, aggregateType, aggregateId])
  @@map("domain_events")
}

// ==========================================================
// AUDIT LOG — append-only, hash-chained (ADR-013)
// Padrão portado de adviser-editor/backend (audit_hash_chain).
// Cada registro encadeia o hash do anterior: adulterar uma linha
// quebra toda a cadeia a partir dela (tamper-evident).
// ==========================================================
model AuditLog {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  seq        Int      // sequência por tenant (1, 2, 3, …)
  action     String   // ex: lgpd.export, lgpd.erase, order.canceled
  entityType String?
  entityId   String?
  actor      String?  // user:xxx | agent | system
  payload    Json

  prevHash   String   // hash do registro anterior ("" no primeiro)
  hash       String   // SHA-256(prevHash + seq + action + canonical(payload))

  createdAt  DateTime @default(now())

  @@unique([tenantId, seq])
  @@index([tenantId, createdAt])
  @@map("audit_logs")
}

// ============================================================
// Rede de atacado B2B (ADR-024 — MCP Server). Marketplace cross-tenant:
// catálogos de várias lojas expostos a compradores (lojas/agentes). Estas
// tabelas NÃO têm RLS por tenant (acesso é da rede, não do operador da loja);
// o servidor MCP controla o acesso na sua própria camada de auth.
// ============================================================
model WholesaleQuote {
  id             String   @id @default(cuid())
  sellerTenantId String   // loja dona do catálogo
  buyerRef       String   // identificador do comprador (loja/agente)
  items          Json     // [{ productId, name, sku, qty, unitWholesaleBRL }]
  totalBRL       Decimal  @db.Decimal(12, 2)
  status         String   @default("open") // open | ordered | expired
  expiresAt      DateTime
  createdAt      DateTime @default(now())

  @@index([sellerTenantId])
  @@index([buyerRef])
  @@map("wholesale_quotes")
}

model WholesaleOrder {
  id             String   @id @default(cuid())
  quoteId        String   @unique
  sellerTenantId String
  buyerRef       String
  totalBRL       Decimal  @db.Decimal(12, 2)
  // Comissão da plataforma (ADR-024 — monetização). Snapshot no fechamento.
  commissionPct  Float    @default(0)
  commissionBRL  Decimal  @default(0) @db.Decimal(12, 2)
  status         String   @default("placed") // placed | confirmed | shipped | delivered | canceled
  trackingCode   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([sellerTenantId])
  @@index([buyerRef])
  @@map("wholesale_orders")
}

// Comprador da rede de atacado B2B (ADR-024). Autenticado por API-key (só o hash
// é guardado). O servidor MCP resolve a key → buyer; cotações/pedidos usam o
// buyer autenticado (não um `buyerRef` que o cliente diz ser).
model B2bBuyer {
  id         String   @id @default(cuid())
  name       String
  apiKeyHash String   @unique  // sha256(hex) da API-key
  tenantId   String?  // se a compradora for uma loja nossa (circular)
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@map("b2b_buyers")
}

// ==========================================================
// FABRICAÇÃO (ADR-030) — insumos, embalagens e ficha técnica
// ==========================================================

// Insumo OU material de embalagem consumido na fabricação/venda. A `category`
// distingue: "ingrediente" (farinha, açúcar — consumido ao PRODUZIR) vs
// "embalagem" (caixa, sacola — consumido ao VENDER/ENTREGAR).
//
// Unidades: `baseUnit` é a unidade de CONSUMO (g, ml, un) — é nela que a receita
// lança as quantidades e que o custo é cotado (`costPerBaseUnit`). `purchaseUnit`
// + `purchaseQtyInBase` descrevem como o insumo é COMPRADO ("saco" = 5000 g), só
// para conveniência de cadastro/recebimento. `stockQty` é o saldo atual na
// `baseUnit` (Fase 1: editável direto; Fase 2: derivado do razão de movimentos).
model RawMaterial {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name      String
  category  String   @default("ingrediente") // ingrediente | embalagem
  baseUnit  String   @default("g")           // g | kg | ml | L | un
  sku       String?

  // Custo por unidade-base (ex.: R$/g). Alimentado manualmente ou pela
  // Mercadológica (melhor preço de fornecedor → custo do insumo).
  costPerBaseUnit Decimal @default(0) @db.Decimal(12, 4)

  // Compra (opcional, conveniência): "1 saco = 5000 g"
  purchaseUnit      String?
  purchaseQtyInBase Decimal? @db.Decimal(12, 4)

  // Estoque atual + ponto de alerta, na baseUnit
  stockQty    Decimal  @default(0) @db.Decimal(12, 3)
  minStockQty Decimal? @db.Decimal(12, 3)

  supplierId String?  // vínculo opcional com a rede de fornecedores (Mercadológica)

  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bomItems  BomItem[]

  @@index([tenantId, category])
  @@index([tenantId, active])
  @@map("raw_materials")
}

// Ficha técnica (Bill of Materials): a composição de um produto fabricado.
// `productId` liga à variante/produto vendido (opcional — uma receita pode existir
// antes do produto). `yieldQty` = quantas unidades de produto a receita rende;
// `lossPct` = perda esperada (massa que sobra, quebra). O custo unitário do
// produto = (Σ itens) × (1 + lossPct/100) ÷ yieldQty.
model BillOfMaterials {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name       String
  productId  String?  // FK lógica para Product (sem constraint: produto pode vir depois)
  variantSku String?  // receita específica de uma variante (ex.: bolo 2kg vs 3kg)

  yieldQty Decimal @default(1) @db.Decimal(12, 3)
  yieldUnit String? // un | kg — só descritivo
  lossPct  Float   @default(0)
  notes    String?

  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items     BomItem[]

  @@index([tenantId, active])
  @@index([tenantId, productId])
  @@map("bills_of_materials")
}

// Linha da ficha técnica: um insumo/embalagem e a quantidade (na baseUnit do
// insumo) que entra na receita.
model BomItem {
  id         String   @id @default(cuid())
  bomId      String
  bom        BillOfMaterials @relation(fields: [bomId], references: [id], onDelete: Cascade)
  materialId String
  material   RawMaterial     @relation(fields: [materialId], references: [id], onDelete: Restrict)

  quantity Decimal @db.Decimal(12, 4) // na baseUnit do material
  note     String?

  @@index([bomId])
  @@index([materialId])
  @@map("bom_items")
}

// Lote de produção (ADR-030 — Fase 2). Registra a fabricação de N unidades de um
// produto a partir de uma ficha técnica: consome os insumos (baixa em
// RawMaterial.stockQty) e, se for pronta-entrega (`addedToStock`), soma o produto
// acabado ao estoque de vitrine (StockMovement production_in). Sob encomenda
// (`addedToStock=false`) só consome insumos. `consumed` é o snapshot do que foi
// baixado (auditoria/rastreabilidade).
model ProductionBatch {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  bomId      String?  // FK lógica (a ficha pode ser removida depois)
  bomName    String   // snapshot do nome da receita
  productId  String?
  variantSku String?

  quantity     Decimal @db.Decimal(12, 3) // unidades de produto acabado
  addedToStock Boolean @default(false)
  unitCost     Decimal @default(0) @db.Decimal(12, 4)
  totalCost    Decimal @default(0) @db.Decimal(12, 4)

  consumed   Json     // [{ materialId, name, baseUnit, quantity, costPerBaseUnit }]
  note       String?
  actor      String   @default("operator")

  createdAt  DateTime @default(now())

  @@index([tenantId, createdAt])
  @@map("production_batches")
}

// Tarifa de entrega própria (ADR-030 — Fase 3). Um registro por tenant. O modal
// (moto vs carro) é escolhido automaticamente pelo volume do pedido vs
// `motoVolumeLimit`; o preço vem da faixa de distância (`bands`) do modal
// escolhido. Substitui a cotação de transportadora (Melhor Envio) para lojas
// que entregam com motoboy/carro próprio.
model DeliveryTariff {
  id        String   @id @default(cuid())
  tenantId  String   @unique
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Volume máximo que vai de moto (na mesma unidade de Product.deliveryVolume).
  // Acima disso, o pedido vai de carro.
  motoVolumeLimit Float @default(6)

  // Faixas de distância por modal: [{ modal:"moto"|"carro", maxKm, priceBRL }]
  bands     Json     @default("[]")

  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("delivery_tariffs")
}

// Lançamento de cashback (ADR-031). Razão append-only por cliente.
//  - kind "accrual": crédito ganho numa compra; `amountBRL` positivo, `remainingBRL`
//    é quanto ainda está disponível (decrementado nos resgates, FIFO), `expiresAt`
//    é a validade.
//  - kind "redeem": crédito usado num pedido; `amountBRL` negativo, refId = pedido.
//  - kind "expire": crédito que venceu sem uso; `amountBRL` negativo.
// Saldo = Σ remainingBRL dos accruals não-expirados.
model CashbackEntry {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contactId  String
  contact    Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  kind         String   // accrual | redeem | expire | adjust
  amountBRL    Decimal  @db.Decimal(10, 2)            // sinalizado: + entra, - sai
  remainingBRL Decimal  @default(0) @db.Decimal(10, 2) // só accrual: saldo ainda disponível
  orderId      String?
  expiresAt    DateTime?                               // só accrual
  nudgedAt     DateTime?                               // último lembrete de expiração enviado
  note         String?
  createdAt    DateTime @default(now())

  @@index([tenantId, contactId])
  @@index([tenantId, kind, expiresAt])
  @@map("cashback_entries")
}

// Campanha de promoção / broadcast (ADR-031). Envia uma mensagem a um segmento de
// contatos (que deram consentimento e não optaram por sair de "marketing") por
// WhatsApp / e-mail / SMS. Distinto de AdCampaign (Meta Ads — mídia paga).
model MarketingCampaign {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  title     String
  message   String
  subject   String?   // assunto do e-mail
  channels  String[]  // whatsapp | email | sms
  onlyBuyers Boolean  @default(false) // legado/relatório: audience != "todos"
  audience   String   @default("todos") // todos | compradores | inativos (recompra)
  inactiveDays Int?    // p/ audience "inativos": sem comprar há N dias

  status    String   @default("rascunho") // rascunho | enviada
  recipients   Int    @default(0)
  sentWhatsapp Int    @default(0)
  sentEmail    Int    @default(0)
  sentSms      Int    @default(0)
  skipped      Int    @default(0)   // sem canal alcançável
  sentAt    DateTime?
  createdAt DateTime @default(now())

  @@index([tenantId, status])
  @@map("marketing_campaigns")
}

// Lançamento financeiro manual (ADR-032) — fluxo de caixa. Receitas de VENDAS
// vêm automaticamente dos pedidos pagos; aqui ficam despesas (fornecedor, salário,
// aluguel, imposto…) e outras receitas que o operador registra.
model FinancialEntry {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  type        String   // receita | despesa
  category    String   // fornecedor | salario | aluguel | marketing | imposto | outro | venda…
  description String?
  amountBRL   Decimal  @db.Decimal(12, 2)
  date        DateTime // data de caixa (quando pago); p/ pendentes = data do registro
  status      String   @default("pago") // pago | pendente (conta a pagar/receber)
  dueDate     DateTime? // vencimento (contas pendentes)
  createdAt   DateTime @default(now())

  @@index([tenantId, date])
  @@index([tenantId, status, dueDate])
  @@map("financial_entries")
}

// Entregador próprio cadastrado pela loja (ADR-033) — app de entregas para cidade
// do interior. Acessa as próprias corridas por um token (sem senha).
model Courier {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name        String
  phone       String?  // contato (texto puro — é um prestador, não cliente)
  vehicle     String   @default("moto") // moto | carro | bike | a_pe
  active      Boolean  @default(true)
  accessToken String   @unique // link do app do entregador (/entregador/:token)
  createdAt   DateTime @default(now())

  jobs        DeliveryJob[]

  @@index([tenantId])
  @@map("couriers")
}

// Corrida de entrega (ADR-033). Liga um pedido a um entregador próprio e segue o
// ciclo pendente → atribuído → aceito → coletado → entregue (ou cancelado).
model DeliveryJob {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orderId     String
  courierId   String?
  courier     Courier? @relation(fields: [courierId], references: [id], onDelete: SetNull)

  status      String   @default("pendente") // pendente|atribuido|aceito|coletado|entregue|cancelado
  feeBRL      Decimal? @db.Decimal(10, 2)    // pagamento do entregador
  address     String?  // endereço de entrega (snapshot)
  notes       String?
  assignedAt  DateTime?
  acceptedAt  DateTime?
  pickedUpAt  DateTime?
  deliveredAt DateTime?
  createdAt   DateTime @default(now())

  @@index([tenantId, status])
  @@index([courierId, status])
  @@map("delivery_jobs")
}

// Peça serializada (ADR-035 fase 3): cada etiqueta gerada pelo padrão da loja vira
// UMA peça com código único. Permite contar estoque por tamanho e dar baixa na venda.
model Piece {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  code       String   // código completo do padrão (único na loja)
  productId  String?
  variantSku String
  size       String
  sequence   Int      // número sequencial da peça
  status     String   @default("em_estoque") // em_estoque | vendida | baixada
  meta       Json?    // snapshot dos campos manuais (fornecedor/tipo/margem)
  createdAt  DateTime @default(now())
  soldAt     DateTime?

  @@unique([tenantId, code])
  @@index([tenantId, status, size])
  @@index([tenantId, variantSku])
  @@map("pieces")
}
